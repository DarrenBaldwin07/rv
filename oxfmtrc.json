{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"trailingComma": "es5",
	"tabWidth": 2,
	"semi": true,
	"jsxSingleQuote": true,
	"singleQuote": true,
	"bracketSameLine": true,
	"bracketSpacing": true,
	"useTabs": true,
	"experimentalSortPackageJson": false,
	"experimentalTailwindcss": {
		"attributes": ["class", "className"],
		"functions": ["clsx", "cn", "cva", "cx"]
	},
	"printWidth": 80,
	"ignorePatterns": [
		"*.mdx",
		"*.rs",
		".nuxt",
		"nix",
		"packages/database/hooks*",
		"packages/database/vueHooks",
		"packages/database/src/zod*",
		"packages/database/src/zenstack*",
		"packages/database/src/generated*",
		"packages/database/src/openapi*",
		"packages/database/prisma*",
		"pnpm-lock.yaml",
		"apps/cdk/cdk.out/**",
		"apps/raycast/**",
		"apps/tylers-admin/**"
	]
}
